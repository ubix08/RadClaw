# OpenCode SDK / server
# Always connects to an existing OpenCode server (never spawns a new one).
# Defaults to http://127.0.0.1:4096 if OPENCODE_SERVER_URL is empty.
OPENCODE_SERVER_URL=
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096
OPENCODE_MODEL=
OPENCODE_CONFIG_DIR=.

# App
APP_NAME=rad
LOG_LEVEL=info
HEARTBEAT_INTERVAL_MINUTES=30
HEARTBEAT_FILE=workspace/HEARTBEAT.md
WHITELIST_FILE=whitelist.json
WHITELIST_PAIR_TOKEN=

# Telegram (grammy)
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=

# WhatsApp (Baileys)
ENABLE_WHATSAPP=false
# WHATSAPP_AUTH_DIR defaults to ~/.radclaw/whatsapp-auth

# HTTP API / React frontend
# Leave ENABLE_API=true to serve the React frontend and chat API.
# API_ADMIN_KEY and API_CHAT_KEY are separate so chat users cannot access admin endpoints.
# If API_ENABLE_AUTH=false (dev only), no auth is required.
ENABLE_API=true
API_PORT=3100
API_HOSTNAME=0.0.0.0
API_ADMIN_KEY=
API_CHAT_KEY=
API_ENABLE_AUTH=true
API_CORS_ORIGIN=*
