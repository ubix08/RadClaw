# OpenCode — connects to existing server at port 4096
OPENCODE_SERVER_URL=
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096
OPENCODE_MODEL=opencode/big-pickle

# OpenAI-compatible provider keys (e.g. OpenRouter uses OPENROUTER_API_KEY)
OPENROUTER_API_KEY=sk-isCQzw4LCpsWo8uKLktd5gRJD50sZ959EUoNeCIKCZJw1uSVc4YL9AKci62m87li

# App
APP_NAME=monclaw
LOG_LEVEL=info
HEARTBEAT_INTERVAL_MINUTES=30
WHITELIST_FILE=whitelist.json
WHITELIST_PAIR_TOKEN=

# Telegram
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=

# WhatsApp
ENABLE_WHATSAPP=false
# WHATSAPP_AUTH_DIR defaults to ~/.radclaw/whatsapp-auth

# HTTP API
ENABLE_API=true
API_PORT=3100
API_HOSTNAME=0.0.0.0
API_ADMIN_KEY=
API_CHAT_KEY=
API_ENABLE_AUTH=false
API_CORS_ORIGIN=*
